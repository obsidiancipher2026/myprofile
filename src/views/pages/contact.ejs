<%- include('../partials/head') %>
<%- include('../partials/header') %>

<section class="page-hero">
  <div class="container">
    <h1>Contact <span class="accent">Me</span></h1>
    <div class="section-line"></div>
    <p>Let's secure the future together</p>
  </div>
</section>

<section class="section" data-reveal>
  <div class="container">
    <div class="contact-layout">
      <div class="contact-info">
        <h3>Let's Secure the Future Together</h3>
        <p>Open to collaborations with organizations tackling intricate security challenges. Available worldwide for consulting, projects, and CTF competitions.</p>
        <div class="contact-details">
          <div class="contact-item">
            <i class="fas fa-envelope"></i>
            <span>sakingplays@gmail.com</span>
          </div>
          <div class="contact-item">
            <i class="fas fa-map-marker-alt"></i>
            <span>Available Worldwide</span>
          </div>
        </div>
        <div class="contact-social">
          <a href="/social/linkedin" target="_blank" rel="noopener" class="social-icon linkedin"><i class="fab fa-linkedin-in"></i></a>
          <a href="/social/github" target="_blank" rel="noopener" class="social-icon github"><i class="fab fa-github"></i></a>
          <a href="/social/youtube" target="_blank" rel="noopener" class="social-icon youtube"><i class="fab fa-youtube"></i></a>
          <a href="/social/whatsapp" target="_blank" rel="noopener" class="social-icon whatsapp"><i class="fab fa-whatsapp"></i></a>
          <a href="/social/fiverr" target="_blank" rel="noopener" class="social-icon fiverr"><svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M23.07 18.39c-1.09 0-1.96-.9-1.96-2s.87-2 1.96-2 1.96.9 1.96 2-.87 2-1.96 2zm-8.56-5.74v1.42h-2.6v-6.3h2.55c1.56 0 2.37.77 2.37 2.15 0 1.07-.52 1.8-1.3 2.12.94.28 1.52 1.17 1.52 2.34 0 1.48-.95 2.27-2.54 2.27zm-4.82-4.05c0-1.48 1.06-2.36 2.6-2.36h1.48v1.43h-1.35c-.78 0-1.16.39-1.16 1.08v1.56h2.47v1.43h-2.47v2.54h-2.57V9.6h-1zm-5.58 4.05v1.42H5.44v-6.3h2.55c1.56 0 2.37.77 2.37 2.15 0 1.07-.52 1.8-1.3 2.12.94.28 1.52 1.17 1.52 2.34 0 1.48-.95 2.27-2.54 2.27zm-2.25-4.05c0-1.48 1.06-2.36 2.6-2.36h1.48v1.43H9.52c-.78 0-1.16.39-1.16 1.08v1.56h2.47v1.43H8.36v2.54H5.79V9.6H4.86zM0 4.21v15.58h24V4.21H0zm21.98 12.76c-1.49.66-3.2 1.02-5.01 1.02-3.98 0-7.52-1.68-9.46-4.42.57 2.3 2.83 3.96 5.55 3.96 1.59 0 3.04-.57 4.17-1.5v4.94H22V4.21h-3.32v6.65c-1.26-1.38-2.98-2.15-4.85-2.15-3.92 0-7.38 2.54-8.66 6.22.57-2.48 2.83-4.33 5.55-4.33 1.63 0 3.08.6 4.13 1.56V6.18h3.32v10.79h.7z"/></svg></a>
        </div>
        <div class="contact-cv">
          <a href="/cv/download" class="btn btn-primary"><i class="fas fa-download"></i> Download CV</a>
        </div>
      </div>
      <div>
        <div class="contact-form-box">
          <% if (typeof success !== 'undefined' && success) { %>
            <div class="success-message">
              <i class="fas fa-check-circle"></i>
              <p><%= success %></p>
            </div>
          <% } else { %>
            <% if (typeof errors !== 'undefined' && errors && errors.length) { %>
              <div class="error-message">
                <i class="fas fa-exclamation-triangle"></i>
                <ul style="margin:4px 0 0 20px;"><% errors.forEach(function(e) { %><li><%= e %></li><% }); %></ul>
              </div>
            <% } %>
            <form action="/contact" method="POST" class="contact-form" novalidate>
              <div class="form-group">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" value="<%= typeof form !== 'undefined' && form.name ? form.name : '' %>" placeholder="Your Name" required minlength="2">
              </div>
              <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" value="<%= typeof form !== 'undefined' && form.email ? form.email : '' %>" placeholder="your@email.com" required>
              </div>
              <div class="form-group">
                <label for="message">Message</label>
                <textarea id="message" name="message" rows="5" placeholder="Tell me about your security challenges..." required minlength="10"><%= typeof form !== 'undefined' && form.message ? form.message : '' %></textarea>
              </div>
              <button type="submit" class="btn btn-primary btn-block">
                <i class="fas fa-paper-plane"></i> Send Message
              </button>
            </form>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
