<%- include('../../partials/head') %>
<%- include('../../partials/header') %>
<section class="section">
  <div class="container">
    <h1><%= cert ? 'Edit' : 'New' %> Certification</h1>
    <form action="/admin/certifications<%= cert ? '/' + cert.id : '' %>" method="POST" enctype="multipart/form-data" class="admin-form">
      <div class="form-group"><label>Title</label><input type="text" name="title" value="<%= cert ? cert.title : '' %>" required></div>
      <div class="form-group"><label>Issuer</label><input type="text" name="issuer" value="<%= cert ? cert.issuer : '' %>" required></div>
      <div class="form-group"><label>Date</label><input type="date" name="date" value="<%= cert ? new Date(cert.date).toISOString().split('T')[0] : '' %>" required></div>
      <div class="form-group"><label>Credential URL</label><input type="url" name="credentialUrl" value="<%= cert ? cert.credentialUrl : '' %>"></div>
      <div class="form-group"><label>Image</label><input type="file" name="image" accept="image/*"></div>
      <button type="submit" class="btn btn-primary"><%= cert ? 'Update' : 'Create' %> Certification</button>
    </form>
  </div>
</section>
<%- include('../../partials/footer') %>
