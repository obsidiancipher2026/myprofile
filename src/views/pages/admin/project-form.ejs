<%- include('../../partials/head') %>
<%- include('../../partials/header') %>
<section class="section">
  <div class="container">
    <h1><%= project ? 'Edit' : 'New' %> Project</h1>
    <form action="/admin/projects<%= project ? '/' + project.id : '' %>" method="POST" enctype="multipart/form-data" class="admin-form">
      <div class="form-group"><label>Title</label><input type="text" name="title" value="<%= project ? project.title : '' %>" required></div>
      <div class="form-group"><label>Description</label><textarea name="description" rows="5" required><%= project ? project.description : '' %></textarea></div>
      <div class="form-group"><label>Category</label><input type="text" name="category" value="<%= project ? project.category : '' %>"></div>
      <div class="form-group"><label>Project URL</label><input type="url" name="projectUrl" value="<%= project ? project.projectUrl : '' %>"></div>
      <div class="form-group"><label>Tech Stack (comma separated)</label><input type="text" name="techStack" value="<%= project ? project.techStack : '' %>"></div>
      <div class="form-group"><label>Image</label><input type="file" name="image" accept="image/*"></div>
      <button type="submit" class="btn btn-primary"><%= project ? 'Update' : 'Create' %> Project</button>
    </form>
  </div>
</section>
<%- include('../../partials/footer') %>
