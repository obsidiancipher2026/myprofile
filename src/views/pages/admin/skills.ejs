<%- include('../../partials/head') %>
<%- include('../../partials/header') %>
<section class="section">
  <div class="container">
    <div class="admin-header"><h1>Manage Skills</h1><a href="/admin/skills/new" class="btn btn-primary"><i class="fas fa-plus"></i> Add Skill</a></div>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead><tr><th>Name</th><th>Level</th><th>Category</th><th>Order</th><th>Actions</th></tr></thead>
        <tbody>
          <% if (skills && skills.length) { %>
            <% skills.forEach(function(s) { %>
            <tr>
              <td><%= s.name %></td>
              <td><%= s.level %>%</td>
              <td><%= s.category || '-' %></td>
              <td><%= s.sortOrder %></td>
              <td class="actions">
                <a href="/admin/skills/<%= s.id %>/edit" class="btn btn-small"><i class="fas fa-edit"></i></a>
                <form action="/admin/skills/<%= s.id %>/delete" method="POST" style="display:inline"><button type="submit" class="btn btn-small btn-danger" onclick="return confirm('Delete?')"><i class="fas fa-trash"></i></button></form>
              </td>
            </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="5" class="empty-state">No skills yet. <a href="/admin/skills/new">Add one</a>.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</section>
<%- include('../../partials/footer') %>
