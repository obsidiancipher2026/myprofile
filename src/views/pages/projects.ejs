<%- include('../partials/head') %>
<%- include('../partials/header') %>

<section class="page-hero">
  <div class="container">
    <h1>Project <span class="accent">Gallery</span></h1>
    <div class="section-line"></div>
    <p>Real projects built with cybersecurity and full-stack expertise</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="projects-grid" data-stagger>
      <% if (projects && projects.length) { %>
        <% projects.forEach(function(project) { %>
          <div class="project-card" data-id="<%= project.id %>">
            <div class="project-card-image">
              <% if (project.imageUrl) { %>
                <img src="<%= project.imageUrl %>" alt="<%= project.title %>" loading="lazy">
              <% } else { %>
                <div class="project-card-icon">
                  <i class="fas fa-shield-halved"></i>
                </div>
              <% } %>
            </div>
            <div class="project-card-body">
              <h3><%= project.title %></h3>
              <p><%= project.description?.substring(0, 120) %><%= project.description?.length > 120 ? '...' : '' %></p>
              <% if (project.techStack) { %>
                <div class="project-tags">
                  <% project.techStack.split(',').forEach(function(tag) { %>
                    <span class="tag"><%= tag.trim() %></span>
                  <% }); %>
                </div>
              <% } %>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="empty-state full">
          <i class="fas fa-folder-open"></i>
          <h3>No Projects Yet</h3>
          <p>Projects are being added. Check back soon.</p>
        </div>
      <% } %>
    </div>
    <div style="text-align:center;margin-top:40px;color:var(--text-muted);font-size:0.85rem;">
      <i class="fas fa-info-circle"></i> Live demo links and GitHub repositories will be added once available.
    </div>
  </div>
</section>

<div class="modal-overlay" id="projectModal">
  <div class="modal-content">
    <button class="modal-close">&times;</button>
    <div class="modal-body" id="modalBody">
      <div class="modal-loader"><i class="fas fa-spinner fa-spin"></i></div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
