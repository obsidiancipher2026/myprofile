<%- include('../partials/head') %>
<%- include('../partials/header') %>

<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-orbs">
    <div class="hero-orb"></div>
    <div class="hero-orb"></div>
    <div class="hero-orb"></div>
  </div>
  <div class="hero-particles">
    <canvas id="particle-canvas"></canvas>
  </div>
  <div class="hero-scanlines"></div>
  <div class="hero-layout">
    <div class="hero-content">
      <div class="hero-badge"><i class="fas fa-terminal"></i> Cybersecurity Student &amp; Ethical Hacker</div>
      <h1 class="hero-title"><span class="gradient-text">Shayan Ahmed</span></h1>
      <p class="hero-subtitle">Cybersecurity Student · Director at CyberGuardiansSociety · Cryptography &amp; Steganography Enthusiast · Python Developer · CTF Player</p>
      <p class="hero-tagline">An ethical hacker and full stack developer who thinks like an attacker, builds like an engineer, and leads like a founder.</p>
      <div class="hero-actions">
        <a href="/projects" class="btn btn-primary"><i class="fas fa-shield"></i> View Projects</a>
        <a href="/contact" class="btn btn-outline"><i class="fas fa-envelope"></i> Contact Me</a>
        <a href="/cv/download" class="btn btn-ghost"><i class="fas fa-download"></i> Download CV</a>
      </div>
      <div class="hero-social">
        <a href="/social/linkedin" target="_blank" rel="noopener" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
        <a href="/social/github" target="_blank" rel="noopener" aria-label="GitHub"><i class="fab fa-github"></i></a>
        <a href="/social/youtube" target="_blank" rel="noopener" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
        <a href="/social/whatsapp" target="_blank" rel="noopener" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
        <a href="/social/fiverr" target="_blank" rel="noopener" aria-label="Fiverr"><svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M23.07 18.39c-1.09 0-1.96-.9-1.96-2s.87-2 1.96-2 1.96.9 1.96 2-.87 2-1.96 2zm-8.56-5.74v1.42h-2.6v-6.3h2.55c1.56 0 2.37.77 2.37 2.15 0 1.07-.52 1.8-1.3 2.12.94.28 1.52 1.17 1.52 2.34 0 1.48-.95 2.27-2.54 2.27zm-4.82-4.05c0-1.48 1.06-2.36 2.6-2.36h1.48v1.43h-1.35c-.78 0-1.16.39-1.16 1.08v1.56h2.47v1.43h-2.47v2.54h-2.57V9.6h-1zm-5.58 4.05v1.42H5.44v-6.3h2.55c1.56 0 2.37.77 2.37 2.15 0 1.07-.52 1.8-1.3 2.12.94.28 1.52 1.17 1.52 2.34 0 1.48-.95 2.27-2.54 2.27zm-2.25-4.05c0-1.48 1.06-2.36 2.6-2.36h1.48v1.43H9.52c-.78 0-1.16.39-1.16 1.08v1.56h2.47v1.43H8.36v2.54H5.79V9.6H4.86zM0 4.21v15.58h24V4.21H0zm21.98 12.76c-1.49.66-3.2 1.02-5.01 1.02-3.98 0-7.52-1.68-9.46-4.42.57 2.3 2.83 3.96 5.55 3.96 1.59 0 3.04-.57 4.17-1.5v4.94H22V4.21h-3.32v6.65c-1.26-1.38-2.98-2.15-4.85-2.15-3.92 0-7.38 2.54-8.66 6.22.57-2.48 2.83-4.33 5.55-4.33 1.63 0 3.08.6 4.13 1.56V6.18h3.32v10.79h.7z"/></svg></a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-image-frame">
        <img src="/images/WhatsApp%20Image%202026-03-09%20at%205.52.53%20PM%20(1).jpeg" alt="Shayan Ahmed" class="hero-image">
      </div>
    </div>
  </div>
  <div class="hero-scroll-indicator">
    <span>Scroll</span>
    <i class="fas fa-chevron-down"></i>
  </div>
</section>

<section id="featured-projects" class="section section-alt" data-reveal>
  <div class="container">
    <div class="section-header">
      <h2>Featured <span class="accent">Projects</span></h2>
      <div class="section-line"></div>
      <p>Real-world cybersecurity and full-stack projects</p>
    </div>
    <div class="projects-grid" data-stagger>
      <% if (projects && projects.length) { %>
        <% projects.slice(0, 3).forEach(function(project) { %>
          <div class="project-card" data-id="<%= project.id %>">
            <div class="project-card-image">
              <% if (project.imageUrl) { %>
                <img src="<%= project.imageUrl %>" alt="<%= project.title %>" loading="lazy">
              <% } else { %>
                <div class="project-card-icon">
                  <i class="fas fa-shield-halved"></i>
                </div>
              <% } %>
            </div>
            <div class="project-card-body">
              <h3><%= project.title %></h3>
              <p><%= project.description?.substring(0, 120) %><%= project.description?.length > 120 ? '...' : '' %></p>
              <% if (project.techStack) { %>
                <div class="project-tags">
                  <% project.techStack.split(',').forEach(function(tag) { %>
                    <span class="tag"><%= tag.trim() %></span>
                  <% }); %>
                </div>
              <% } %>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="empty-state">
          <i class="fas fa-code-branch"></i>
          <p>Projects coming soon.</p>
        </div>
      <% } %>
    </div>
    <% if (projects && projects.length > 3) { %>
      <div class="section-cta" style="text-align:center;margin-top:40px;">
        <a href="/projects" class="btn btn-outline">View All Projects <i class="fas fa-arrow-right"></i></a>
      </div>
    <% } %>
  </div>
</section>



<div class="modal-overlay" id="projectModal">
  <div class="modal-content">
    <button class="modal-close">&times;</button>
    <div class="modal-body" id="modalBody">
      <div class="modal-loader"><i class="fas fa-spinner fa-spin"></i></div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
