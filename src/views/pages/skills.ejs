<%- include('../partials/head') %>
<%- include('../partials/header') %>

<section class="page-hero">
  <div class="container">
    <h1>Technical <span class="accent">Skills</span></h1>
    <div class="section-line"></div>
    <p>13 core skills across security, development, systems, and operations</p>
  </div>
</section>

<section class="section" data-reveal>
  <div class="container">
    <div class="skills-category-grid" data-stagger>
      <% categories.forEach(function(cat) { %>
        <div class="skill-cat-card">
          <div class="skill-cat-icon"><i class="fas <%= cat.icon %>"></i></div>
          <h4><%= cat.name %></h4>
          <span class="cat-label"><%= cat.skills.length %> Skills</span>
          <div class="skill-list">
            <% cat.skills.forEach(function(s) { %>
              <span><i class="fas fa-circle"></i> <%= s %></span>
            <% }); %>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<section class="section section-alt" data-reveal>
  <div class="container">
    <div class="section-header">
      <h2>Complete <span class="accent">Skills</span></h2>
      <div class="section-line"></div>
    </div>
    <div class="skills-tag-grid" data-stagger>
      <% skills.forEach(function(skill) { %>
        <span class="skill-tag">
          <i class="fas <%= skill.icon || 'fa-shield' %>"></i>
          <%= skill.name %>
        </span>
      <% }); %>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
