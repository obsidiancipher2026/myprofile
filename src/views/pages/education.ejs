<%- include('../partials/head') %>
<%- include('../partials/header') %>

<section class="page-hero">
  <div class="container">
    <h1>My <span class="accent">Education</span></h1>
    <div class="section-line"></div>
    <p>Corrected academic records sourced from official CV</p>
  </div>
</section>

<section class="section" data-reveal>
  <div class="container">
    <div class="edu-grid" data-stagger>
      <% education.forEach(function(edu) { %>
        <div class="edu-card">
          <div class="edu-card-header">
            <div class="edu-icon"><i class="fas <%= edu.icon %>"></i></div>
            <div class="edu-meta">
              <span class="edu-type"><%= edu.level %></span>
              <span class="edu-year"><%= edu.years %></span>
            </div>
          </div>
          <div class="edu-card-body">
            <h3><%= edu.school %></h3>
            <p class="edu-location"><i class="fas fa-map-marker-alt"></i> <%= edu.location %></p>
            <% if (edu.parts.length > 0) { %>
              <div class="edu-details">
                <% edu.parts.forEach(function(part) { %>
                  <div class="edu-stat">
                    <span class="edu-stat-label"><%= part.label %></span>
                    <span class="edu-stat-value"><%= part.pct %></span>
                    <span class="edu-stat-sub">(<%= part.value %>)</span>
                  </div>
                <% }); %>
              </div>
              <div class="edu-grade"><%= edu.grade %></div>
            <% } else { %>
              <div class="edu-grade" style="border-color: var(--accent-dim); color: var(--text-secondary); border-style: dashed;"><%= edu.grade %></div>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
